{
  "name": "budget-mobile-app",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test:model": "node --import tsx --test tests/**/*.test.ts",
    "build:ios": "npx eas build --platform ios --profile production",
    "submit:ios": "npx eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.4.1",
    "expo": "~53.0.0",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "~18.1.11",
    "expo-haptics": "~14.1.4",
    "expo-pdf-text-extract": "^1.0.1",
    "expo-print": "~14.1.4",
    "expo-sharing": "~13.1.5",
    "expo-status-bar": "~2.2.3",
    "firebase": "^12.11.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-purchases": "^9.15.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3"
  }
}
